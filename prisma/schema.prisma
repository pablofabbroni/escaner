generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Comprobante {
  id                Int      @id @default(autoincrement())
  fechaEmision      DateTime
  cuitReceptor      String
  tipoComprobante   String
  condicionReceptor String
  puntoVenta        String
  nroComprobante    String
  total             Float
  createdAt         DateTime @default(now())
}
