generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Comprobante {
  id              Int      @id @default(autoincrement())
  fechaEmision    DateTime
  cuitEmisor      String
  cuitReceptor    String
  tipoComprobante String
  puntoVenta      String
  nroComprobante  String
  total           Float
  createdAt       DateTime @default(now())
}
